<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Sirena">
  <link rel="manifest" href="/manifest.json">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <title>Sirena - Control de Inventario</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div id="toast" class="toast"></div>
  <nav>
    <div class="nav-left">
      <button id="btn-back" class="btn-back" style="display:none" onclick="volverMenu()">←</button>
      <h1 class="nav-logo">SIRENA <span class="nav-logo-sub">DE JUAN</span></h1>
    </div>
    <div id="user-info" class="user-info" style="display:none">
      <span id="user-email" class="user-email"></span>
      <button id="btn-salir" class="btn-salir">Salir</button>
    </div>
  </nav>

  <!-- Main menu: 3 category buttons -->
  <div id="main-menu" class="main-menu">
    <div class="main-menu-grid">
      <button class="category-btn" onclick="irACategoria('stocks')">
        <span class="category-icon">📦</span>
        <span class="category-label">STOCKS</span>
        <span class="category-desc">Ingresos, Salidas, Ventas, Almacenes, Stocks, Reportes, Precios</span>
      </button>
      <button class="category-btn" onclick="irACategoria('barra')">
        <span class="category-icon">🍸</span>
        <span class="category-label">BARRA</span>
        <span class="category-desc">Recetas, Stock y Base de Datos de la Barra</span>
      </button>
      <button class="category-btn" onclick="irACategoria('cocina')">
        <span class="category-icon">🍳</span>
        <span class="category-label">COCINA</span>
        <span class="category-desc">Recetas, Stock y Base de Datos de la Cocina</span>
      </button>
    </div>
  </div>

  <!-- Tabs bar (STOCKS) -->
  <div id="tabs-bar" class="tabs-bar" style="display:none">
    <div class="tabs">
      <button class="tab" data-tab="ingresos">Ingresos</button>
      <button class="tab" data-tab="salidas">Salidas</button>
      <button class="tab" data-tab="ventas">Ventas</button>
      <button class="tab" data-tab="bajas">Bajas</button>
      <button class="tab active" data-tab="almacenes">Almacenes</button>
      <button class="tab" data-tab="stocks">Stocks</button>
      <button class="tab" data-tab="reportes">Reportes</button>
      <button class="tab" data-tab="precios">Precios</button>
    </div>
  </div>

  <!-- Tabs bar (BARRA) -->
  <div id="tabs-barra" class="tabs-bar" style="display:none">
    <div class="tabs">
      <button class="sub-tab" data-subtab="ingresos" onclick="cambiarSubTab('ingresos')">Ingresos</button>
      <button class="sub-tab" data-subtab="ventas" onclick="cambiarSubTab('ventas')">Ventas</button>
      <button class="sub-tab" data-subtab="bajas" onclick="cambiarSubTab('bajas')">Bajas</button>
      <button class="sub-tab" data-subtab="stock" onclick="cambiarSubTab('stock')">Stock</button>
      <button class="sub-tab active" data-subtab="recetas" onclick="cambiarSubTab('recetas')">Recetas</button>
      <button class="sub-tab" data-subtab="basedatos" onclick="cambiarSubTab('basedatos')">Base de Datos</button>
    </div>
  </div>

  <!-- Tabs bar (COCINA) -->
  <div id="tabs-cocina" class="tabs-bar" style="display:none">
    <div class="tabs">
      <button class="sub-tab active" data-subtab="recetas" onclick="cambiarSubTab('recetas','cocina')">Recetas</button>
      <button class="sub-tab" data-subtab="stock" onclick="cambiarSubTab('stock','cocina')">Stock</button>
      <button class="sub-tab" data-subtab="basedatos" onclick="cambiarSubTab('basedatos','cocina')">Base de Datos</button>
    </div>
  </div>

  <div class="container" id="container">
    <div id="tab-almacenes" class="tab-content active">
      <div class="header-actions">
        <h2>Almacenes</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="fecha-almacenes" onchange="cargarAlmacenes(this.value)"></label>
          <input type="text" id="buscar-item" placeholder="Buscar item..." oninput="buscarEnTabla(this.value, 'accordion-almacenes')">
          <button class="btn-guardar-dia" onclick="guardarDia()">💾 GUARDAR</button>
          <button class="btn-detalles" onclick="exportarExcel()">Exportar</button>
        </div>
      </div>
      <div id="accordion-almacenes"></div>
    </div>

    <div id="tab-ingresos" class="tab-content">
      <div class="header-actions">
        <h2>Ingresos</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="fecha-ingresos" onchange="cargarIngresos(this.value)"></label>
          <input type="text" id="buscar-ingreso" placeholder="Buscar item..." oninput="buscarEnTabla(this.value, 'accordion-ingresos')">
          <button class="btn-guardar-dia" onclick="guardarIngresos()">💾 GUARDAR INGRESOS</button>
          <button class="btn-detalles" onclick="verDetallesIngresos()">📋 DETALLES</button>
        </div>
      </div>
      <div id="accordion-ingresos"></div>
    </div>

    <div id="tab-salidas" class="tab-content">
      <div class="header-actions">
        <h2>Salidas</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="fecha-salidas" onchange="cargarSalidas(this.value)"></label>
          <input type="text" id="buscar-salida" placeholder="Buscar item..." oninput="buscarEnTabla(this.value, 'accordion-salidas')">
          <button class="btn-guardar-dia" onclick="guardarSalidas()">💾 GUARDAR SALIDAS</button>
          <button class="btn-detalles" onclick="verDetallesSalidas()">📋 DETALLES</button>
        </div>
      </div>
      <div id="accordion-salidas"></div>
    </div>

    <div id="tab-ventas" class="tab-content">
      <div class="header-actions">
        <h2>Ventas</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="fecha-ventas" onchange="cargarVentas(this.value)"></label>
          <input type="text" id="buscar-venta" placeholder="Buscar item..." oninput="buscarEnTabla(this.value, 'accordion-ventas')">
          <button class="btn-guardar-dia" onclick="guardarVentas()">💾 GUARDAR VENTAS</button>
          <button class="btn-detalles" onclick="verDetallesVentas()">📋 DETALLES</button>
        </div>
      </div>
      <div id="accordion-ventas"></div>
    </div>

    <div id="tab-bajas" class="tab-content">
      <div class="header-actions">
        <h2>Bajas</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="fecha-bajas" onchange="cargarBajas(this.value)"></label>
          <input type="text" id="buscar-baja" placeholder="Buscar item..." oninput="buscarEnTabla(this.value, 'accordion-bajas')">
          <button class="btn-guardar-dia" onclick="guardarBajas()">💾 GUARDAR BAJAS</button>
          <button class="btn-detalles" onclick="verDetallesBajas()">📋 DETALLES</button>
        </div>
      </div>
      <div id="accordion-bajas"></div>
    </div>

    <div id="tab-stocks" class="tab-content">
      <div class="header-actions">
        <h2>Stocks</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="fecha-stocks" onchange="cargarStocks()"></label>
          <input type="text" id="buscar-stock" placeholder="Buscar item..." oninput="buscarEnTabla(this.value, 'accordion-stocks')">
          <button class="btn-guardar-dia" onclick="guardarMinimosStocks()">💾 GUARDAR MINIMOS</button>
          <button class="btn-detalles" onclick="verReporteStocksBajos()">📋 REPORTES</button>
        </div>
      </div>
      <div id="accordion-stocks"></div>
    </div>

    <div id="tab-reportes" class="tab-content">
      <div class="header-actions">
        <h2>Reportes</h2>
        <div class="controles-dia">
          <label>Fecha: <input type="date" id="reporte-fecha-dif" onchange="cargarReporteDiferencias()"></label>
          <button onclick="exportarDiferencias()">Exportar</button>
          <button onclick="exportarVinos()" style="background:#4a148c;color:#fff;border:none;padding:0.5rem 1rem;border-radius:4px;cursor:pointer;">Exportar Vinos</button>
        </div>
      </div>
      <div id="reporte-diferencias"></div>
    </div>

    <div id="tab-precios" class="tab-content">
      <div class="header-actions">
        <h2>Precios</h2>
        <div class="controles-dia">
          <input type="text" id="buscar-precio-item" placeholder="Buscar item..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:250px;" oninput="buscarEnTabla(this.value, 'accordion-precios')">
          <button class="btn-guardar-dia" onclick="guardarPreciosAlmacen()">💾 GUARDAR PRECIOS</button>
          <button class="btn-detalles" onclick="exportarPrecios()">Exportar</button>
        </div>
      </div>
      <div id="accordion-precios"></div>
    </div>

    <div id="tab-barra" class="tab-content">
      <div id="sub-barra-ingresos" class="sub-tab-content">
        <div class="header-actions">
          <h2>Ingresos Barra</h2>
          <div class="controles-dia">
            <label>Fecha: <input type="date" id="fecha-barra-ingresos" onchange="cargarBarraMovimientos('ingresos')"></label>
            <input type="text" id="buscar-barra-ingresos" placeholder="Buscar item..." oninput="buscarEnTabla(this.value,'accordion-barra-ingresos')">
            <button class="btn-guardar-dia" onclick="guardarBarraMovimientos('ingresos')">💾 GUARDAR INGRESOS</button>
            <button class="btn-detalles" onclick="verDetallesBarra('ingresos')">📋 DETALLES</button>
          </div>
        </div>
        <div id="accordion-barra-ingresos"></div>
      </div>

      <div id="sub-barra-ventas" class="sub-tab-content">
        <div class="header-actions">
          <h2>Ventas Barra</h2>
          <div class="controles-dia">
            <label>Fecha: <input type="date" id="fecha-barra-ventas" onchange="cargarBarraMovimientos('ventas')"></label>
            <input type="text" id="buscar-barra-ventas" placeholder="Buscar receta..." oninput="buscarTablaBarra(this.value,'accordion-barra-ventas','tr[data-receta]')">
            <button class="btn-guardar-dia" onclick="guardarBarraMovimientos('ventas')">💾 GUARDAR VENTAS</button>
            <button class="btn-detalles" onclick="verDetallesBarra('ventas')">📋 DETALLES</button>
          </div>
        </div>
        <div id="accordion-barra-ventas"></div>
      </div>

      <div id="sub-barra-bajas" class="sub-tab-content">
        <div class="header-actions">
          <h2>Bajas Barra</h2>
          <div class="controles-dia">
            <label>Fecha: <input type="date" id="fecha-barra-bajas" onchange="cargarBarraMovimientos('bajas')"></label>
            <input type="text" id="buscar-barra-bajas" placeholder="Buscar item..." oninput="buscarEnTabla(this.value,'accordion-barra-bajas')">
            <button class="btn-guardar-dia" onclick="guardarBarraMovimientos('bajas')">💾 GUARDAR BAJAS</button>
            <button class="btn-detalles" onclick="verDetallesBarra('bajas')">📋 DETALLES</button>
          </div>
        </div>
        <div id="accordion-barra-bajas"></div>
      </div>

      <div id="sub-barra-recetas" class="sub-tab-content active">
        <div class="header-actions">
          <h2>Recetas</h2>
          <div class="controles-dia" style="display:flex;align-items:center;gap:0.5rem;">
            <input type="text" id="buscar-receta" placeholder="Buscar receta..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:250px;" oninput="buscarReceta(this.value)">
            <button onclick="exportarRecetas()">EXPORTAR</button>
          </div>
        </div>
        <div style="margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;padding:1rem;background:#f9f9f9;border-radius:8px;">
          <input type="text" id="nueva-receta-input" placeholder="Nueva receta..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;flex:1;min-width:150px;">
          <select id="nueva-receta-cat" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;">
            <option value="RECETAS BASE">RECETAS BASE</option>
            <option value="Clásicos">Clásicos</option>
            <option value="Mojitos">Mojitos</option>
            <option value="Limonadas">Limonadas</option>
            <option value="DEL BARMAN">DEL BARMAN</option>
            <option value="Chilcanos y Sours">Chilcanos y Sours</option>
          </select>
          <button onclick="guardarReceta()">AGREGAR RECETA</button>
        </div>
        <div id="recetas-container"></div>
      </div>

      <div id="sub-barra-stock" class="sub-tab-content">
        <div class="header-actions">
          <h2>Stock Barra</h2>
          <div class="controles-dia" style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            <input type="text" id="buscar-stock-barra" placeholder="Buscar en stock..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:250px;" oninput="buscarTablaBarra(this.value, 'barra-stock-container', 'tr[data-stock-id]')">
            <input type="text" id="nuevo-stock-input" placeholder="Ingrediente" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:180px;">
            <input type="number" id="nuevo-stock-cant" placeholder="Cant." step="0.01" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:90px;">
            <select id="nuevo-stock-uni" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:90px;">
              <option value="ml">ml</option>
              <option value="unidad">unidad</option>
              <option value="onzas">onzas</option>
              <option value="gramos">gramos</option>
              <option value="kg">kg</option>
              <option value="lt">lt</option>
              <option value="hojas">hojas</option>
              <option value="gotas">gotas</option>
              <option value="rodajas">rodajas</option>
            </select>
            <button onclick="agregarStockBarra()">AGREGAR ITEM</button>
          </div>
        </div>
        <div id="barra-stock-container"></div>
      </div>

      <div id="sub-barra-basedatos" class="sub-tab-content">
        <div class="header-actions">
          <h2>Base de Datos</h2>
          <div class="controles-dia" style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            <input type="text" id="nuevo-precio-input" placeholder="Ingrediente" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:180px;">
            <select id="nuevo-uni-compra" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:110px;">
              <option value="">Unid.Compra</option>
              <option value="KILOS">KILOS</option>
              <option value="GRAMOS">GRAMOS</option>
              <option value="LITRO">LITRO</option>
              <option value="ML">ML</option>
              <option value="ONZAS">ONZAS</option>
              <option value="UNIDAD">UNIDAD</option>
              <option value="HOJAS">HOJAS</option>
              <option value="BOTELLA">BOTELLA</option>
            </select>
            <input type="number" id="nuevo-precio-compra" placeholder="Precio Compra" step="0.01" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:110px;">
            <select id="nuevo-precio-uni" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:90px;">
              <option value="unidad">unidad</option>
              <option value="onzas">onzas</option>
              <option value="gramos">gramos</option>
              <option value="kg">kg</option>
              <option value="lt">lt</option>
              <option value="ml">ml</option>
              <option value="hojas">hojas</option>
              <option value="gotas">gotas</option>
            </select>
            <input type="number" id="nuevo-precio-precio" placeholder="Precio S/." step="0.01" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:100px;">
            <button onclick="agregarPrecio()">AGREGAR ITEM</button>
            <input type="text" id="buscar-precios" placeholder="Buscar..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:200px;" oninput="buscarTablaBarra(this.value, 'barra-precios-container', 'tr[data-precio-id]')">
            <button class="btn-guardar-dia" onclick="guardarPreciosBase()">💾 GUARDAR</button>
            <button class="btn-detalles" onclick="exportarBaseDatos()">EXPORTAR</button>
          </div>
        </div>
        <div id="barra-precios-container"></div>
      </div>
    </div>

    <div id="tab-cocina" class="tab-content">
      <div id="sub-cocina-recetas" class="sub-tab-content active">
        <div class="header-actions">
          <h2>Recetas</h2>
          <div class="controles-dia">
            <button class="btn-guardar-dia" onclick="alert('Próximamente')">➕ AGREGAR RECETA</button>
          </div>
        </div>
        <div id="cocina-recetas-container"><p>Sin recetas aún.</p></div>
      </div>

      <div id="sub-cocina-stock" class="sub-tab-content">
        <div class="header-actions">
          <h2>Stock Cocina</h2>
          <div class="controles-dia">
            <input type="text" id="nuevo-cocina-stock-input" placeholder="Nuevo ingrediente..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:200px;">
            <input type="number" id="nuevo-cocina-stock-cant" placeholder="Cantidad" step="0.01" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:100px;">
            <select id="nuevo-cocina-stock-uni" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;">
              <option value="unidad">unidad</option>
              <option value="onzas">onzas</option>
              <option value="gramos">gramos</option>
              <option value="kg">kg</option>
              <option value="lt">lt</option>
              <option value="ml">ml</option>
            </select>
            <button class="btn-guardar-dia" onclick="alert('Próximamente')">➕ AGREGAR</button>
          </div>
        </div>
        <div id="cocina-stock-container"><p>Sin stock aún.</p></div>
      </div>

      <div id="sub-cocina-basedatos" class="sub-tab-content">
        <div class="header-actions">
          <h2>Base de Datos</h2>
          <div class="controles-dia">
            <input type="text" id="nuevo-cocina-precio-input" placeholder="Nuevo ingrediente..." style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:200px;">
            <select id="nuevo-cocina-precio-uni" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;">
              <option value="unidad">unidad</option>
              <option value="onzas">onzas</option>
              <option value="gramos">gramos</option>
              <option value="kg">kg</option>
              <option value="lt">lt</option>
              <option value="ml">ml</option>
            </select>
            <input type="number" id="nuevo-cocina-precio-precio" placeholder="Precio" step="0.01" style="padding:0.5rem;border:1px solid #ccc;border-radius:4px;font-size:0.9rem;width:100px;">
            <button class="btn-guardar-dia" onclick="alert('Próximamente')">➕ AGREGAR</button>
          </div>
        </div>
        <div id="cocina-precios-container"><p>Sin datos aún.</p></div>
      </div>
    </div>

    <div id="modal" class="modal">
    <div class="modal-content">
      <span class="close" onclick="cerrarModal()">&times;</span>
      <div id="modal-body"></div>
      <datalist id="recetas-base-datalist"></datalist>
    </div>
  </div>

  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
  <script>
    const firebaseConfig = {
      apiKey: "AIzaSyArHIucq8Asn3dF8egTor_p3EOmxVWA9Bs",
      authDomain: "la-sirena-stocks.firebaseapp.com",
      projectId: "la-sirena-stocks",
      storageBucket: "la-sirena-stocks.firebasestorage.app",
      messagingSenderId: "511759764045",
      appId: "1:511759764045:web:2ec3009aa950b55dc56a04",
      measurementId: "G-SEB0S1G3FF"
    };
    firebase.initializeApp(firebaseConfig);
  </script>
  <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
  <script src="/app.js"></script>
</body>
</html>
